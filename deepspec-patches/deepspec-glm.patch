+                # Non-finite-gradient guard. A rare bad batch / numerical spike (e.g. the draft's
+                # logits sharpen as it converges and a softmax overflows) yields an inf/nan grad;
+                # clipping keeps it non-finite, and optimizer.step() would then poison EVERY weight
+                # -> loss=nan forever. Skip the update (last-good weights preserved), drop the bad
+                # grads, and continue. Standard EAGLE/spec-decode training-stability guard; lossless
+                # (one batch skipped). Without it, shallow grad-accum trains clean for hundreds of
+                # steps then dies on a single batch (observed: clean to step 210, nan at 220).
+                if torch.isfinite(grad_norm):
+                    self.optimizer.step()
+                else:
+                    self.model.zero_grad(set_to_none=True)
