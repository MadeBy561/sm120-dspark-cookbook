+# GLM-5.2 (GlmMoeDsa). The tokenizer renders:
+#   [gMASK]<sop>\n<|system|>Reasoning Effort: Medium-high<|user|>{u}<|assistant|><think></think>{a}
+# No explicit assistant-end token — the next <|user|> (or end-of-string) delimits the turn. We keep
+# system_prompt=None (the tokenizer template injects its own "Reasoning Effort" system) and put loss
+# on the whole assistant body incl. the (empty for thinking-off) <think></think> + answer.
+TEMPLATE_REGISTRY.register(
+    "glm",
+    ChatTemplate(
+        assistant_header="<|assistant|>",
+        user_header="<|user|>",
+        system_prompt=None,
+        end_of_turn_token="<|user|>",
+        assistant_loss_prefix=None,
+    ),
+)
+
 
 class GeneralParser:
     def __init__(self, tokenizer, chat_template):
